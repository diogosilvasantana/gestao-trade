datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Conta {
  id            String  @id @default(cuid())
  tipo          String
  descricao     String?
  status        String  @default("Ativa")
  saldoInicial  Decimal @db.Decimal(15, 2)
  saldoAtual    Decimal @db.Decimal(15, 2)
  rollbackAtivo Boolean @default(true)

  contaReal      ContaReal?
  contaMesa      ContaMesa?
  operacoes      Operacao[]
  historicoSaldo HistoricoSaldo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContaReal {
  id                 String  @id @default(cuid())
  contaId            String  @unique
  conta              Conta   @relation(fields: [contaId], references: [id], onDelete: Cascade)
  corretora          String
  tipoOperacao       String
  moeda              String  @default("BRL")
  contratosAtuais    Int     @default(1)
  regraContratosBase Decimal @default(1000) @db.Decimal(15, 2)
}

model ContaMesa {
  id                String    @id @default(cuid())
  contaId           String    @unique
  conta             Conta     @relation(fields: [contaId], references: [id], onDelete: Cascade)
  tipo              String
  meta              Decimal   @db.Decimal(15, 2)
  perdaDiariaMaxima Decimal   @db.Decimal(15, 2)
  eliminaNaPerda    Boolean   @default(true)
  dataInicio        DateTime
  dataFim           DateTime?
  statusAprovacao   String    @default("Em Avaliacao")
}

model Operacao {
  id           String   @id @default(cuid())
  contaId      String
  conta        Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  data         DateTime @default(now())
  ativo        String
  quantidade   Int
  precoEntrada Decimal  @db.Decimal(15, 4)
  precoSaida   Decimal  @db.Decimal(15, 4)
  comissao     Decimal  @default(0) @db.Decimal(10, 2)
  resultado    Decimal  @db.Decimal(15, 2)
  tipo         String
  observacoes  String?
  status       String   @default("Executada")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HistoricoSaldo {
  id                  String   @id @default(cuid())
  contaId             String
  conta               Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  data                DateTime @default(now())
  saldoAnterior       Decimal  @db.Decimal(15, 2)
  saldoNovo           Decimal  @db.Decimal(15, 2)
  tipoMovimento       String
  contratosAnteriores Int?
  contratosNovos      Int?
  houveRollback       Boolean  @default(false)
  motivoRollback      String?
}

model TaxaOperacional {
  id               String   @id @default(uuid())
  ativoSigla       String   @unique
  nome             String
  valorPorContrato Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("taxa_operacional")
}
